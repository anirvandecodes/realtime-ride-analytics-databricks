{
  "datasets": [
    {
      "name": "ds_kpis",
      "displayName": "Live KPIs",
      "queryLines": [
        "SELECT total_revenue_inr, cancellation_rate_pct, active_drivers, avg_fare_inr, CAST(ROUND(total_rides * (100 - cancellation_rate_pct) / 100, 0) AS BIGINT) AS completed_rides FROM workspace.realtime.gold_live_kpis"
      ]
    },
    {
      "name": "ds_revenue",
      "displayName": "Revenue per Minute",
      "queryLines": [
        "SELECT minute_bucket, revenue_inr, completed_rides FROM workspace.realtime.gold_revenue_per_minute ORDER BY minute_bucket"
      ]
    },
    {
      "name": "ds_status",
      "displayName": "Ride Status Mix",
      "queryLines": [
        "SELECT status, CAST(ride_count AS BIGINT) AS ride_count FROM workspace.realtime.gold_ride_status_breakdown ORDER BY ride_count DESC"
      ]
    },
    {
      "name": "ds_cities",
      "displayName": "City Performance",
      "queryLines": [
        "SELECT city, ROUND(revenue_inr, 0) AS revenue_inr, CAST(total_rides AS BIGINT) AS total_rides FROM workspace.realtime.gold_rides_by_city ORDER BY revenue_inr DESC"
      ]
    },
    {
      "name": "ds_zones",
      "displayName": "Top Revenue Zones",
      "queryLines": [
        "SELECT zone_id, city, ROUND(total_revenue_inr, 0) AS total_revenue_inr, CAST(completed_rides AS BIGINT) AS completed_rides, ROUND(avg_fare_inr, 0) AS avg_fare_inr FROM workspace.realtime.gold_top_zones ORDER BY total_revenue_inr DESC LIMIT 10"
      ]
    },
    {
      "name": "ds_cancel_reasons",
      "displayName": "Cancellation Reasons",
      "queryLines": [
        "SELECT city, COALESCE(NULLIF(cancellation_reason,''), status) AS reason, CAST(COUNT(ride_id) AS BIGINT) AS cancellation_count FROM workspace.realtime.silver_ride_events WHERE event_date = CURRENT_DATE() AND is_cancelled = true GROUP BY city, COALESCE(NULLIF(cancellation_reason,''), status) ORDER BY cancellation_count DESC"
      ]
    },
    {
      "name": "ds_pickup",
      "displayName": "Pickup Demand",
      "queryLines": [
        "SELECT city, pickup_area, zone_id, CAST(COUNT(ride_id) AS BIGINT) AS total_rides, CAST(SUM(CASE WHEN is_cancelled THEN 1 ELSE 0 END) AS BIGINT) AS cancelled_rides, ROUND(SUM(CASE WHEN is_cancelled THEN 1 ELSE 0 END) * 100.0 / COUNT(ride_id), 1) AS cancel_rate_pct FROM workspace.realtime.silver_ride_events WHERE event_date = CURRENT_DATE() GROUP BY city, pickup_area, zone_id ORDER BY total_rides DESC"
      ]
    }
  ],
